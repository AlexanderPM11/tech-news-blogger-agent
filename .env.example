# Selección de Proveedor (Opciones: ollama, nvidia, openai, gemini)
MODEL_PROVIDER="openai"

# Configuración de Ollama Local (si se usa ollama)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="ollama/gemma4:e2b"

# Configuración NVIDIA NIM
NVIDIA_API_KEY="tu-api-key-nvidia-aqui"
NVIDIA_MODEL="nvidia_nim/google/gemma-3n-e4b-it"

# Configuración OpenAI
OPENAI_API_KEY="tu-api-key-openai-aqui"
# Se recomienda usar gpt-4o-mini por defecto para reducir costos en el desarrollo
OPENAI_MODEL="openai/gpt-4o-mini"

# Configuración Google Gemini
GEMINI_API_KEY="tu-api-key-gemini-aqui"
GEMINI_MODEL="gemini/gemini-2.5-flash"

# Seguridad API (se requiere esta key en el header x-api-key de las llamadas HTTP a /chat)
API_SECRET_KEY="tu-secret-key-para-desarrollo"

# Variables de entorno adicionales para tus herramientas personalizadas:
# MY_API_KEY="tu-clave-herramienta-aqui"

# Configuración WordPress (para obtener las categorías dinámicamente)
WORDPRESS_CATEGORIES_URL="https://blog.apolanco.com/wp-json/wp/v2/categories"
